{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/books", "dest": "/api/books.js" },
    { "src": "/api/books/(.*)", "dest": "/api/books/[id].js" },
    { "src": "/(.*)", "dest": "/client/$1" }
  ]
}
